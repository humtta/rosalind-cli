{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.3/.schema/devbox.schema.json",

  "packages": {
    "go": "1.26.3"
  },

  "shell": {
    "scripts": {
      "build": "go build -o ./out/rosalind ./cmd/rosalind/",
      "run": "go run ./cmd/rosalind/",
      "fmt": "go fmt ./...",
      "vet": "go vet ./...",
      "check": [
        "devbox run fmt",
        "devbox run vet"
      ]
    }
  }
}
